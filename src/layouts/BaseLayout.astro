---
interface Props {
  title: string;
  description?: string;
  ogUrl?: string;
  ogImage?: string;
  ogSiteName?: string;
}

const {
  title,
  description = 'atohs(あとーす)のポートフォリオサイトです。メディア運営、執筆・編集、文字起こし、写真撮影、校正などを行っています。',
  ogUrl = 'https://atohs.me',
  ogImage = 'https://atohs.me/src/ogp.png',
  ogSiteName = 'atohs.me',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@atohsaaa" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/src/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/yakuhanjp@3.4.1/dist/css/yakuhanjp.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v6.0.0/css/all.css" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3S8S7JGPEZ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-3S8S7JGPEZ');
    </script>
  </head>
  <body>
    <slot />
    <footer></footer>
  </body>
</html>

<style is:global>
  @import '../styles/main.css';
</style>

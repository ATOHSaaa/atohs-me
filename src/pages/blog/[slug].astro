---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import ShareButtons from '../../components/ShareButtons.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postUrl = `https://atohs.me/blog/${post.id}`;
const ogImage = `https://atohs.me/blog/${post.id}/og.png`;

const formatDate = (date: Date) =>
  date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
---

<BaseLayout
  title={`${post.data.title} | atohs.me`}
  description={post.data.description}
  ogUrl={postUrl}
  ogImage={ogImage}
>
  <SiteHeader />
  <article class="main blog-post">
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/blog">blog<span class="breadcrumb-slash">/</span></a>
    </nav>
    <p class="blog-meta">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </p>
    <h1 class="blog-title">{post.data.title}</h1>
    <ShareButtons url={postUrl} title={post.data.title} />
    <div class="blog-body">
      <Content />
    </div>
    <ShareButtons url={postUrl} title={post.data.title} />
  </article>
</BaseLayout>

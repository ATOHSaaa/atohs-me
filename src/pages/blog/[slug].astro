---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { createPostDescription } from '../../lib/post-description';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postUrl = `https://atohs.me/blog/${post.id}`;
const ogImage = `https://atohs.me/blog/${post.id}/og.png`;
const description = createPostDescription(post.body ?? '');

const formatDate = (date: Date) =>
  date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
---

<BaseLayout
  title={`${post.data.title} | atohs.me`}
  description={description}
  ogUrl={postUrl}
  ogImage={ogImage}
>
  <SiteHeader />
  <main id="main-content" class="main">
    <article class="blog-post">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href="/">Home</a><span class="breadcrumb-slash">/</span><a href="/blog">blog</a><span
          class="breadcrumb-slash">/</span>
      </nav>
      <h1 class="blog-title">{post.data.title}</h1>
      <p class="blog-meta">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      </p>
      <ShareButtons url={postUrl} title={post.data.title} />
      <div class="blog-body">
        <Content />
      </div>
      <ShareButtons url={postUrl} title={post.data.title} />
    </article>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout
  title="お問い合わせ | atohs.me"
  description="atohs(あとーす)へのお問い合わせはこちらから。"
  ogUrl="https://atohs.me/contact"
>
  <SiteHeader />
  <main id="main-content" class="main">
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">Home</a><span class="breadcrumb-slash">/</span>
    </nav>
    <h1 class="page-title">お問い合わせ</h1>
    <p>
      <a href="mailto:info@tadeku.net">info@tadeku.net</a>にメールをお送りいただくか、<a
        href="https://twitter.com/atohsaaa"
        target="_blank"
        rel="noopener noreferrer"
        >TwitterのDM<span class="visually-hidden">（新しいタブで開く）</span></a
      >でお声がけください。
    </p>
  </main>
</BaseLayout>

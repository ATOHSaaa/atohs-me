---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
---

<BaseLayout title="atohs.me | あとーすのプロフィール">
  <SiteHeader isHome />
  <main id="main-content" class="main">
    <div class="name-box">
      <h2 id="real-name">氏名<br /><span>name</span></h2>
      <span class="name">伊藤 祥太</span><br />
      <span class="name-detail"
        >SHOTA ITO<br />
        Born in November 13, 1993 🎉</span
      >
      <h2 id="about">プロフィール<br /><span>Profile</span></h2>
      <p class="profile-text">
        熊本大学文学部文学科卒。印刷会社で営業・Webディレクター、IT系ベンチャー企業でPdM・カスタマーサポートとして勤務した後に独立。ことばや文章に関することを中心に、企画・制作を担当します。
      </p>
    </div>

    <h2>職歴<br /><span>My business experience</span></h2>
    <table class="custom-table">
      <thead class="visually-hidden">
        <tr>
          <th scope="col">期間</th>
          <th scope="col">内容</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span>2021/09 - 現在</span></td>
          <td>個人事業主 （屋号：蓼食う本の虫）</td>
        </tr>
        <tr>
          <td><span>2022/07 - 2025/03</span></td>
          <td>
            <a href="https://tooon.co.jp/" target="_blank" rel="noopener noreferrer"
              >Tooon株式会社<span class="visually-hidden">（新しいタブで開く）</span></a
            >
            カスタマーサポート・ライターなど （業務委託）
          </td>
        </tr>
        <tr>
          <td><span>2018/04 - 2021/08</span></td>
          <td>
            <a href="https://www.pixiv.co.jp/" target="_blank" rel="noopener noreferrer"
              >ピクシブ株式会社<span class="visually-hidden">（新しいタブで開く）</span></a
            >
            プロダクトマネージャー・カスタマーサポート （正社員）
          </td>
        </tr>
        <tr>
          <td><span>2016/04 - 2018/03</span></td>
          <td>印刷会社 営業・Webディレクター （正社員）</td>
        </tr>
      </tbody>
    </table>
    <a href="/my-business-experience"><p class="more"><span>職歴詳細を見る</span></p></a>

    <h2>ブログ<br /><span>Blog</span></h2>
    {
      latestPosts.length === 0 ? (
        <p>まだ記事はありません。</p>
      ) : (
        <ul class="blog-list">
          {latestPosts.map((post) => (
            <li class="blog-list-item">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      )
    }
    <p class="blog-more"><a href="/blog">ブログをもっと読む</a></p>

    <h2>個人プロジェクト<br /><span>Personal projects</span></h2>
    <div class="container">
      <div class="item">
        <a class="item-link" href="https://tadeku.net" target="_blank" rel="noopener noreferrer">
          <img src="/src/tadeku.png" alt="" />
          <h3>蓼食う本の虫</h3>
          <span class="visually-hidden">（新しいタブで開く）</span>
        </a>
        <span>読む・書くを身近にする文芸Webメディア。2016年3月から運営しています。</span>
      </div>
      <div class="item">
        <a class="item-link" href="/cat-in-the-park">
          <img src="/src/cat.png" alt="" />
          <h3>Cat in the park.</h3>
        </a>
        <span>作業用の猫動画を投稿するプロジェクトです。</span>
      </div>
      <div class="item">
        <a class="item-link" href="https://magicology.jp" target="_blank" rel="noopener noreferrer">
          <img src="/src/magicology.png" alt="" />
          <h3>日本魔法魔術学会</h3>
          <span class="visually-hidden">（新しいタブで開く）</span>
        </a>
        <span>魔法魔術に関する論文・調査報告を掲載しています。</span>
      </div>
      <div class="item">
        <a class="item-link" href="https://maho.online" target="_blank" rel="noopener noreferrer">
          <img src="/src/maho.png" alt="" />
          <h3>Maho ONLINE</h3>
          <span class="visually-hidden">（新しいタブで開く）</span>
        </a>
        <span>賢い魔法使いのためのニュースメディアです。</span>
      </div>
    </div>

    <h2>リンク<br /><span>Links</span></h2>
    <div class="links">
      <a href="https://twitter.com/atohsaaa" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">
          <i class="fab fa-twitter" aria-hidden="true"></i>Twitter<span class="visually-hidden"
            >（新しいタブで開く）</span
          >
        </p></a
      >
      <a href="https://instagram.com/atohsaaa" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">
          <i class="fab fa-instagram" aria-hidden="true"></i>Instagram<span class="visually-hidden"
            >（新しいタブで開く）</span
          >
        </p></a
      >
      <a href="https://www.facebook.com/shota.ito.9" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">
          <i class="fab fa-facebook-f" aria-hidden="true"></i>Facebook<span class="visually-hidden"
            >（新しいタブで開く）</span
          >
        </p></a
      >
      <a href="https://www.linkedin.com/in/atohs" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">
          <i class="fab fa-linkedin" aria-hidden="true"></i>LinkedIn<span class="visually-hidden"
            >（新しいタブで開く）</span
          >
        </p></a
      >
      <a href="https://note.com/atohsaaa/" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">
          <i class="fas fa-pen-to-square" aria-hidden="true"></i>note<span class="visually-hidden"
            >（新しいタブで開く）</span
          >
        </p></a
      >
      <a href="https://youtrust.jp/users/atohs" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">YOUTRUST<span class="visually-hidden">（新しいタブで開く）</span></p></a
      >
      <a href="https://www.wantedly.com/id/shota_ito_i" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">Wantedly<span class="visually-hidden">（新しいタブで開く）</span></p></a
      >
      <a href="https://atohs.press" target="_blank" rel="noopener noreferrer"
        ><p class="link-item">個人ブログ<span class="visually-hidden">（新しいタブで開く）</span></p></a
      >
    </div>

    <h2 id="contact">お問い合わせ<br /><span>Contact</span></h2>
    <div>
      <p>
        info@tadeku.netにメールをお送りいただくか、<a href="https://twitter.com/atohsaaa" target="_blank" rel="noopener noreferrer"
          >TwitterのDM<span class="visually-hidden">（新しいタブで開く）</span></a
        >でお声がけください。
      </p>
    </div>
  </main>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import catImage from '../cat.png';
import mahoImage from '../maho.png';
import tadekuImage from '../tadeku.png';
import { formatDate } from '../lib/format-date';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="atohs.me | あとーすのプロフィール">
  <SiteHeader isHome />
  <main id="main-content" class="main">
    <div class="name-box">
      <img class="profile-icon" src="/src/favicon.ico" alt="" width="128" height="128" />
      <div class="name-body">
        <p class="name-detail">
          <span class="name-detail-line name-primary">あとーす（atohs）, 伊藤祥太（ITO SHOTA）</span>
          <span class="name-detail-line">Born on November 13, 1993 🎉 / Live in Kumamoto 🧸</span>
          <span class="name-detail-line">Website Development / Web Marketing / Writing / Editing</span>
        </p>
      </div>
    </div>
    <p class="profile-text">
      熊本大学文学部文学科卒。印刷会社で営業・Webディレクター、IT系ベンチャー企業でPdM・カスタマーサポートとして勤務した後に独立。ことばや文章に関することを中心に、企画・制作を担当します。
    </p>

    <h2>ブログ</h2>
    {
      latestPosts.length === 0 ? (
        <p>まだ記事はありません。</p>
      ) : (
        <ul class="blog-list">
          {latestPosts.map((post) => (
            <li class="blog-list-item">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      )
    }
    <p class="blog-more"><a href="/blog">ブログをもっと読む</a></p>

    <h2>職歴</h2>
    <ul class="career-list">
      <li class="career-item">
        <span class="date-range">
          <span class="date-start">2021.09</span>
          <span class="date-sep" aria-hidden="true">-</span>
          <span class="date-end date-end--current">現在</span>
        </span>
        個人事業主 （屋号：<a href="https://tadeku.net" target="_blank" rel="noopener noreferrer">蓼食う本の虫</a>）
        <ul class="career-list">
          <li class="career-item">
            <span class="date-range">
              <span class="date-start">2022.07</span>
              <span class="date-sep" aria-hidden="true">-</span>
              <span class="date-end">2025.03</span>
            </span>
            <a href="https://tooon.co.jp/" target="_blank" rel="noopener noreferrer"
              >Tooon株式会社<span class="visually-hidden">（新しいタブで開く）</span></a
            >
            CS・マーケ （業務委託）
          </li>
        </ul>
      </li>
      <li class="career-item">
        <span class="date-range">
          <span class="date-start">2018.04</span>
          <span class="date-sep" aria-hidden="true">-</span>
          <span class="date-end">2021.08</span>
        </span>
        <a href="https://www.pixiv.co.jp/" target="_blank" rel="noopener noreferrer"
          >ピクシブ株式会社<span class="visually-hidden">（新しいタブで開く）</span></a
        >
        PdM・CS （正社員）
      </li>
      <li class="career-item">
        <span class="date-range">
          <span class="date-start">2016.04</span>
          <span class="date-sep" aria-hidden="true">-</span>
          <span class="date-end">2018.03</span>
        </span>
        印刷会社 営業・Webディレクター （正社員）
      </li>
    </ul>
    <a href="/my-business-experience"><p class="more"><span>職歴詳細を見る</span></p></a>

    <h2>個人プロジェクト</h2>
    <div class="container">
      <div class="item">
        <a class="item-link" href="https://tadeku.net" target="_blank" rel="noopener noreferrer">
          <Image
            src={tadekuImage}
            alt=""
            widths={[360, 720]}
            sizes="(max-width: 720px) 90vw, 346px"
            format="webp"
            loading="lazy"
            decoding="async"
          />
          <h3>蓼食う本の虫</h3>
          <span class="visually-hidden">（新しいタブで開く）</span>
        </a>
        <span>読む・書くを身近にする文芸Webメディア。2016年3月から運営しています。</span>
      </div>
      <div class="item">
        <a class="item-link" href="/cat-in-the-park">
          <Image
            src={catImage}
            alt=""
            widths={[360, 720]}
            sizes="(max-width: 720px) 90vw, 346px"
            format="webp"
            loading="lazy"
            decoding="async"
          />
          <h3>Cat in the park.</h3>
        </a>
        <span>作業用の猫動画を投稿するプロジェクトです。</span>
      </div>
      <div class="item">
        <a class="item-link" href="https://tools.tadeku.net" target="_blank" rel="noopener noreferrer">
          <Image
            src={tadekuImage}
            alt=""
            widths={[360, 720]}
            sizes="(max-width: 720px) 90vw, 346px"
            format="webp"
            loading="lazy"
            decoding="async"
          />
          <h3>tadeku-tools</h3>
          <span class="visually-hidden">（新しいタブで開く）</span>
        </a>
        <span>蓼食う本の虫が提供する、執筆に役立つツールをまとめています。</span>
      </div>
      <div class="item">
        <a class="item-link" href="https://maho.online" target="_blank" rel="noopener noreferrer">
          <Image
            src={mahoImage}
            alt=""
            widths={[360, 720]}
            sizes="(max-width: 720px) 90vw, 346px"
            format="webp"
            loading="lazy"
            decoding="async"
          />
          <h3>Maho ONLINE</h3>
          <span class="visually-hidden">（新しいタブで開く）</span>
        </a>
        <span>賢い魔法使いのためのニュースメディアです。</span>
      </div>
    </div>
  </main>
</BaseLayout>

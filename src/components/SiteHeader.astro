---
interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
const pathname = Astro.url.pathname;
const isBlog = pathname === '/blog' || pathname.startsWith('/blog/');
---

<div class="header-top">
  <div class="header-inner">
    {
      isHome ? (
        <h1 class="header-logo">
          <a href="/">atohs.me</a>
        </h1>
      ) : (
        <p class="header-logo">
          <a href="/">atohs.me</a>
        </p>
      )
    }
    <nav class="header-links" aria-label="メニュー">
      <a class="header-link" href="/blog" aria-current={isBlog ? 'page' : undefined}>blog</a>
      <a class="header-link" href="/#contact">contact</a>
    </nav>
  </div>
</div>

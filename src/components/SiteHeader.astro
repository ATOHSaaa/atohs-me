---
interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
const pathname = Astro.url.pathname;
const isBlog = pathname === '/blog' || pathname.startsWith('/blog/');
const isContact = pathname === '/contact';
---

<div class="header-top">
  <div class="header-inner">
    {
      isHome ? (
        <h1 class="header-logo">
          <a href="/">
            <img class="header-logo-icon" src="/src/favicon.ico" alt="" width="28" height="28" />
            atohs.me
          </a>
        </h1>
      ) : (
        <p class="header-logo">
          <a href="/">
            <img class="header-logo-icon" src="/src/favicon.ico" alt="" width="28" height="28" />
            atohs.me
          </a>
        </p>
      )
    }
    <nav class="header-links" aria-label="メニュー">
      <a class="header-link" href="/blog" aria-current={isBlog ? 'page' : undefined}>blog</a>
      <a class="header-link" href="/contact" aria-current={isContact ? 'page' : undefined}>contact</a>
    </nav>
  </div>
</div>

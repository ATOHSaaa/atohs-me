---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(`${title}\n`);
const hatenaUrl = `https://b.hatena.ne.jp/entry/panel/?url=${encodedUrl}`;
const xUrl = `https://x.com/intent/post?text=${encodedTitle}&url=${encodedUrl}`;
---

<div class="share-buttons">
  <a
    class="share-button share-hatena"
    href={hatenaUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="はてなブックマークに追加（新しいタブで開く）"
  >
    B!
  </a>
  <a
    class="share-button share-x"
    href={xUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Xでシェア（新しいタブで開く）"
  >
    X
  </a>
  <button
    type="button"
    class="share-button share-link"
    data-share-url={url}
    aria-label="リンクをコピー"
  >
    <i class="fa-solid fa-link" aria-hidden="true"></i>
  </button>
</div>

<script>
  document.querySelectorAll('.share-link').forEach((button) => {
    button.addEventListener('click', async () => {
      const url = button.dataset.shareUrl;
      if (!url) return;

      const originalLabel = button.getAttribute('aria-label') ?? 'リンクをコピー';
      const originalContent = button.innerHTML;

      try {
        await navigator.clipboard.writeText(url);
        button.innerHTML = '<i class="fa-solid fa-check" aria-hidden="true"></i>';
        button.setAttribute('aria-label', 'リンクをコピーしました');
      } catch {
        window.prompt('リンクをコピーしてください', url);
        return;
      }

      window.setTimeout(() => {
        button.innerHTML = originalContent;
        button.setAttribute('aria-label', originalLabel);
      }, 1500);
    });
  });
</script>

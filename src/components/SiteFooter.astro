---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isBlog = pathname === '/blog' || pathname.startsWith('/blog/');
const isContact = pathname === '/contact';
---

<footer class="footer-top">
  <div class="footer-inner">
    <nav class="footer-links" aria-label="フッターメニュー">
      <a class="footer-link" href="/" aria-current={isHome ? 'page' : undefined}>Home</a>
      <a class="footer-link" href="/blog" aria-current={isBlog ? 'page' : undefined}>blog</a>
      <a class="footer-link" href="/contact" aria-current={isContact ? 'page' : undefined}>contact</a>
      <a
        class="footer-link footer-social"
        href="https://twitter.com/atohsaaa"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter @atohsaaa（新しいタブで開く）"
      >
        <i class="fab fa-twitter" aria-hidden="true"></i>
      </a>
    </nav>
  </div>
</footer>
